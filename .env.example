# ── Accounts (optional) ──────────────────────────────────────────────────────
# Real username/password logins, with each person's alpha portfolio and theta
# ledger saved server-side. This replaces the old PIN gate.
#
# BOTH variables must be set to turn accounts on. When either is unset the app
# runs open — single-user, data in the browser's localStorage — exactly as it
# did before, so local dev and first deploys never lock you out.

# Postgres connection string — any provider works (Neon, Supabase, Vercel
# Postgres). After setting it:
#   npm run db:push                              # create the tables
#   npm run create-user -- <username> <password> # add a login (run per person)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# NextAuth session-signing secret. Generate one with:  npx auth secret
AUTH_SECRET=

# ── AI features (optional) ───────────────────────────────────────────────────
# Claude API key for the AI features — the daily brief and dry-powder allocator
# in alpha, and the monthly money brief in theta. Optional — when unset, those
# sections degrade gracefully and everything else still works. Each makes at
# most one cached model call per day per portfolio/ledger shape.
ANTHROPIC_API_KEY=sk-ant-...

# ── Market data enrichment (optional) ─────────────────────────────────────────
# Finnhub API key — a second live provider that fills the fundamentals Yahoo
# leaves empty (common for newly-listed tickers with no statement history yet:
# margins, ROIC, growth, beta). Gap-fill only — it never overrides Yahoo. Two
# calls per symbol, 12h-cached, well inside the free tier's 60-requests/minute
# budget. When unset, the app runs on Yahoo alone.
FINNHUB_API_KEY=

# Financial Modeling Prep API key for enriched fundamentals. When set, ROIC,
# FCF growth, and revenue-by-region data are sourced from FMP (cleaner than
# Yahoo's keyless feed). When unset, the app runs on Yahoo Finance alone.
# Capped at 3 calls per symbol, 12h-cached to respect the free tier's
# 250-requests/day budget. Optional — the app works fine without it.
FMP_API_KEY=
