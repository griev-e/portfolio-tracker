# 4-digit PIN for the lock screen. Set this in Vercel → Project → Settings →
# Environment Variables. When unset, the gate is disabled (open access) —
# convenient for local dev, required to be set in production if you want
# the app private.
ACCESS_PIN=1234

# Claude API key for the AI features — the daily brief on the Intelligence page
# and the dry-powder allocator on the Rebalance page. Optional — when unset,
# both degrade gracefully to a hint and everything else still works. Each makes
# at most one cached model call per day per portfolio shape.
ANTHROPIC_API_KEY=sk-ant-...
