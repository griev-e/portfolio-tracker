# 4-digit PIN for the lock screen. Set this in Vercel → Project → Settings →
# Environment Variables. When unset, the gate is disabled (open access) —
# convenient for local dev, required to be set in production if you want
# the app private.
ACCESS_PIN=1234

# Claude API key for the AI daily brief on the Intelligence page. Optional —
# when unset, the brief section collapses to a hint and everything else on
# the page still works. One short model call per day per portfolio shape.
ANTHROPIC_API_KEY=sk-ant-...
